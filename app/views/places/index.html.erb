<h1 class="mb-3">Places</h1>

<div class="mb-3">
  <a class="btn btn-primary" href="/places/new">New place</a>
</div>

<ul class="list-group">
  <% for place in @places %>
    <li class="list-group-item">
      <a href="/places/<%= place["id"] %>"><%= place["name"] %></a>
    </li>
  <% end %>
</ul>