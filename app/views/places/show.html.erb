<h1 class="mb-3"><%= @place["name"] %></h1>

<div class="mb-3">
  <a class="btn btn-primary" href="/entries/new?place_id=<%= @place["id"] %>">New Post</a>
  <a class="btn btn-secondary" href="/places">Back</a>
</div>

<div class="row">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4 mb-3">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>

          <% if entry.uploaded_image.attached? %>
            <img class="img-fluid rounded" src="<%= url_for(entry.uploaded_image) %>">
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>